// SECCIÓN 1 — CREACIÓN DE COLECCIÓN CON VALIDACIÓN DE SCHEMA

use("buggyfit");
db.createCollection("historial", {
  validator: {
    $jsonSchema: {
      bsonType: "object",
      title: "Validación de documento Historial",
      required: [
        "_id",
        "_class",
        "ejercicios",
        "fechaFin",
        "idRutina",
        "idUsuario",
        "nombreRutina",
        "volumenTotalKG"
      ],
      properties: {
        _id: {
          bsonType: "objectId",
          description: "Identificador único generado por MongoDB"
        },
        _class: {
          bsonType: "string",
          description: "Clase Java mapeada por Spring Data MongoDB"
        },
        idUsuario: {
          bsonType: "long",
          description: "FK lógica al idUsuario de MySQL — obligatorio"
        },
        idRutina: {
          bsonType: "long",
          description: "FK lógica al idRutina de MySQL — obligatorio"
        },
        nombreRutina: {
          bsonType: "string",
          description: "Nombre de la rutina desnormalizado (Extended Reference Pattern)"
        },
        fechaFin: {
          bsonType: "date",
          description: "Fecha y hora en que finalizó la sesión de entrenamiento"
        },
        volumenTotalKG: {
          bsonType: "double",
          description: "Volumen total levantado en kg — sum(peso * reps) por sesión (Computed Pattern)"
        },
        ejercicios: {
          bsonType: "array",
          minItems: 1,
          description: "Lista de ejercicios realizados en la sesión (Bucket Pattern)",
          items: {
            bsonType: "object",
            required: ["idEjercicio", "nombreEjercicio", "orden", "series"],
            properties: {
              idEjercicio: {
                bsonType: "long",
                description: "FK lógica al idEjercicio de MySQL"
              },
              nombreEjercicio: {
                bsonType: "string",
                description: "Nombre desnormalizado del ejercicio"
              },
              orden: {
                bsonType: "int",
                minimum: 1,
                description: "Posición del ejercicio dentro de la rutina"
              },
              series: {
                bsonType: "array",
                minItems: 1,
                items: {
                  bsonType: "object",
                  required: ["numeroSerie", "pesoKG", "repeticiones", "descansoSegundo"],
                  properties: {
                    numeroSerie:     { bsonType: "int",    minimum: 1 },
                    pesoKG:          { bsonType: "double", minimum: 0 },
                    repeticiones:    { bsonType: "int",    minimum: 1 },
                    descansoSegundo: { bsonType: "int",    minimum: 0 }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  validationLevel:  "strict",
  validationAction: "error"
});


db.historial.createIndex({ idUsuario: 1, fechaFin: -1 }); 
db.historial.createIndex({ idRutina: 1 });                 
db.historial.createIndex({ fechaFin: -1 });             
db.historial.createIndex({ volumenTotalKG: -1 });         

print("Colección 'historial' ");



