use("buggyfit");
db.historial.find(
  { idUsuario: Long("2") },
  { nombreRutina: 1, fechaFin: 1, volumenTotalKG: 1, _id: 0 }
).sort({ fechaFin: -1 });

// Última sesión registrada por cada usuario 
use("buggyfit");
db.historial.aggregate([
  { $sort: { idUsuario: 1, fechaFin: -1 } },
  {
    $group: {
      _id:           "$idUsuario",
      ultimaFecha:   { $first: "$fechaFin" },
      ultimaRutina:  { $first: "$nombreRutina" },
      ultimoVolumen: { $first: "$volumenTotalKG" }
    }
  },
  { $sort: { _id: 1 } },
  {
    $project: {
      idUsuario:     "$_id",
      ultimaRutina:  1,
      ultimaFecha:   1,
      ultimoVolumen: 1,
      _id: 0
    }
  }
]);


// Ranking de volumen total acumulado por usuario
use("buggyfit");
db.historial.aggregate([
  {
    $group: {
      _id:           "$idUsuario",
      volumenTotal:  { $sum: "$volumenTotalKG" },
      totalSesiones: { $count: {} }
    }
  },
  { $sort: { volumenTotal: -1 } },
  {
    $project: {
      idUsuario:     "$_id",
      volumenTotal:  1,
      totalSesiones: 1,
      _id: 0
    }
  }
]);

// Sesiones por rutina + volumen promedio
use("buggyfit");
db.historial.aggregate([
  {
    $group: {
      _id:         "$nombreRutina",
      sesiones:    { $count: {} },
      volumenProm: { $avg: "$volumenTotalKG" },
      volumenMax:  { $max: "$volumenTotalKG" }
    }
  },
  { $sort: { sesiones: -1 } },
  {
    $project: {
      rutina:      "$_id",
      sesiones:    1,
      volumenProm: { $round: ["$volumenProm", 2] },
      volumenMax:  1,
      _id: 0
    }
  }
]);


