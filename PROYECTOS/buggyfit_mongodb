// Total de series realizadas por sesión 
use("buggyfit");
db.historial.aggregate([
  { $unwind: "$ejercicios" },
  {
    $group: {
      _id:          "$_id",
      nombreRutina: { $first: "$nombreRutina" },
      idUsuario:    { $first: "$idUsuario" },
      fechaFin:     { $first: "$fechaFin" },
      totalSeries:  { $sum: { $size: "$ejercicios.series" } }
    }
  },
  { $sort: { totalSeries: -1 } },
  {
    $project: {
      idUsuario:    1,
      nombreRutina: 1,
      fechaFin:     1,
      totalSeries:  1,
      _id: 0
    }
  }
]);


